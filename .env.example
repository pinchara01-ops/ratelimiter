# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rateforge
DB_USER=rateforge
DB_PASSWORD=rateforge

# PostgreSQL Container Configuration
POSTGRES_DB=rateforge
POSTGRES_USER=rateforge
POSTGRES_PASSWORD=rateforge

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# gRPC Server Configuration
GRPC_PORT=9090

# Authentication Configuration
# Set to true to enable API key authentication
AUTH_ENABLED=false
# Comma-separated list of valid API keys (e.g., "key1,key2,key3")
AUTH_API_KEYS=

# Metrics/Actuator Authentication
# Credentials for accessing /actuator/metrics and /actuator/prometheus endpoints
# Health endpoint (/actuator/health) is always public
METRICS_USER=metrics
METRICS_PASSWORD=metrics
