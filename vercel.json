{
  "buildCommand": "cd dashboard-service && npm run build",
  "outputDirectory": "dashboard-service/.next",
  "installCommand": "cd dashboard-service && npm install",
  "framework": "nextjs",
  "env": {
    "ANALYTICS_GRPC_URL": "@analytics-grpc-url",
    "CONFIG_GRPC_URL":    "@config-grpc-url",
    "RATELIMIT_GRPC_URL": "@ratelimit-grpc-url"
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
